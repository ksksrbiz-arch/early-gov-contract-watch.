ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here
ALPACA_PAPER=true
BUY_NOTIONAL=300
MIN_CONTRACT_AMOUNT=10000000
POLL_INTERVAL_MINUTES=30
MAX_DAILY_TRADES=2
SELL_AFTER_DAYS=5
TAKE_PROFIT_PCT=12
STOP_LOSS_PCT=6
SLACK_WEBHOOK=
LOG_LEVEL=INFO

# --- Dashboard v2 (all optional) ---
# Lightweight mode: turn analytics/anomalies/history off for a fast snapshot.
DASHBOARD_ENABLE_ANALYTICS=true
DASHBOARD_ENABLE_ANOMALIES=true
DASHBOARD_ENABLE_HISTORY=true
# History file used to compute snapshot-to-snapshot deltas.
DASHBOARD_HISTORY_FILE=dashboard_history.json
DASHBOARD_HISTORY_LIMIT=30
# Default export profile when --profile is not passed: compact | full
DASHBOARD_EXPORT_PROFILE=full
# Minimum confidence tier required for a ticker match to be eligible to trade
# in the eligibility view (none | low | medium | high). Display-only — does
# not change live trading behavior.
DASHBOARD_TICKER_MIN_CONFIDENCE=medium
# Trend window sizes (days / ISO weeks) shown in the overview.
DASHBOARD_TREND_DAYS=14
DASHBOARD_TREND_WEEKS=4
