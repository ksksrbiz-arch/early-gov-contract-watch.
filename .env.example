# ─── Alpaca credentials ────────────────────────────────────────────────────
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here
ALPACA_PAPER=true

# ─── Trading parameters ─────────────────────────────────────────────────────
MIN_CONTRACT_AMOUNT=10000000
POLL_INTERVAL_MINUTES=30
MAX_DAILY_TRADES=2
DAYS_LOOKBACK=7
MATERIALITY_THRESHOLD=0.005
LOG_LEVEL=INFO

# ─── Phase 1 — Quick Profit ─────────────────────────────────────────────────
QUICK_BUY_NOTIONAL=300
QUICK_HOLD_HOURS=48
QUICK_TAKE_PROFIT_PCT=12
QUICK_STOP_LOSS_PCT=5
VOLUME_SPIKE_MULTIPLIER=2.0
MAX_SPREAD_PCT=0.005

# ─── Phase 2 — Large Profit ─────────────────────────────────────────────────
LARGE_BUY_NOTIONAL=2000
PHASE2_MATERIALITY_THRESHOLD=0.0075
PHASE2_TAKE_PROFIT_PCT=20
TRAILING_STOP_PCT=8
TRAILING_STOP_DAYS=14

# ─── Notifications ──────────────────────────────────────────────────────────
SLACK_WEBHOOK=

# ─── Web dashboard ──────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# Set to true to start the bot loop automatically when the dashboard launches.
BOT_AUTOSTART=false
# Flask debug mode (never enable in production).
DASHBOARD_DEBUG=false

# ─── Dashboard v2 toggles (all optional) ────────────────────────────────────
DASHBOARD_ENABLE_ANALYTICS=true
DASHBOARD_ENABLE_ANOMALIES=true
DASHBOARD_ENABLE_HISTORY=true
DASHBOARD_HISTORY_FILE=dashboard_history.json
DASHBOARD_HISTORY_LIMIT=30
DASHBOARD_EXPORT_PROFILE=full
DASHBOARD_TICKER_MIN_CONFIDENCE=medium
DASHBOARD_TREND_DAYS=14
DASHBOARD_TREND_WEEKS=4
